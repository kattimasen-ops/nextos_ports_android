# DYSMANTLE (NextOS Elite) — gptokeyb
# ATENCAO: o parser do gptokeyb NAO aceita comentario na linha do valor —
# comentarios SEMPRE em linha propria.
#
# Teclas->acoes do binario (android_shim, DYSMANTLE_INPUT=gptk):
#   x=A c=B q=X t=Y enter=START esc=SELECT
#   h=L1 j=R1 k=L2 l=R2 n=L3 m=R3 setas=dpad wasd=stick esq
# Sair: SELECT+START

a = x
b = c
x = q
y = t

start = enter
back = esc

l1 = h
l2 = k
r1 = j
r2 = l
l3 = n
r3 = m

up = up
down = down
left = left
right = right

# stick esq -> wasd (digital; diagonal normalizada no binario)
left_analog_up = w
left_analog_down = s
left_analog_left = a
left_analog_right = d

# stick dir -> MOUSE (inofensivo: o jogo NAO usa mouse; a CAMERA vem do stick
# direito lido NATIVAMENTE pelo binario via SDL). NUNCA deixar sem mapeamento:
# em muitos devices o gptokeyb cai pro DPAD por padrao -> o stick direito
# dispararia os QUICK SLOTS de item (bug relatado). Mouse o jogo ignora.
right_analog_up = mouse_movement_up
right_analog_down = mouse_movement_down
right_analog_left = mouse_movement_left
right_analog_right = mouse_movement_right

deadzone_y = 15000
