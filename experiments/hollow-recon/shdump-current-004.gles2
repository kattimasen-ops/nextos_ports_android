#version 100
#define ATTRIBUTE_IN attribute
#define VARYING_IN varying
#define VARYING_OUT varying
/* DECLARE_FRAG_COLOR removed for GLES2 */
#define FRAG_COLOR gl_FragColor
#define SAMPLE_TEXTURE_2D texture2D

precision highp float;
ATTRIBUTE_IN vec4 vertex;
uniform vec4 uvOffsetAndScale;
VARYING_OUT vec2 texCoord;
void main()
{
    gl_Position = vec4(vertex.xy, 0.0, 1.0);
    texCoord = vertex.zw * uvOffsetAndScale.zw + uvOffsetAndScale.xy;
}
